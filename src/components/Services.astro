---

<section id="servicios" class="bg-arena-light">
  <!-- Section header — scrolls away normally, not sticky -->
  <div class="text-center px-4 pt-24 pb-16">
    <p class="font-body text-xs tracking-[0.25em] uppercase text-[#A63228] font-medium mb-4">Lo que hacemos</p>
    <h2 class="reveal font-heading text-texto text-[clamp(2.5rem,5vw,4rem)] font-light mb-4 leading-[1.1]">
      Nuestros Servicios
    </h2>
    <p class="reveal font-body text-texto-light text-lg font-light [transition-delay:0.1s]">
      Elegí el tratamiento ideal para vos
    </p>
    <div class="reveal w-16 h-px bg-amapola mx-auto mt-8 [transition-delay:0.2s]"></div>
  </div>

  <!-- Stacking cards container -->
  <div>
    {services.map((service, i) => {
      return (
        <div>
          <div
            class="flex flex-col shadow-[0_-2px_30px_rgba(0,0,0,0.08)]"
            style={`background-color: ${service.cardBg};`}
          >
            <!-- Header bar -->
            <div
              class="flex items-center px-8 py-[1.2rem] gap-4 shrink-0"
              style={`background-color: ${service.headerBg};`}
            >
              <!-- Left accent bar -->
              <div
                class="w-1 h-8 rounded-sm shrink-0"
                style={`background-color: ${service.accentColor};`}
              ></div>
              <!-- Index -->
              <span
                class="font-body text-xs tracking-[0.2em] font-medium uppercase shrink-0"
                style={`color: ${service.accentColor};`}
              >
                0{i + 1}
              </span>
              <!-- Title -->
              <h3
                class="font-heading text-xl font-normal text-[#3D3028] tracking-[0.02em] flex-1"
              >
                {service.title}
              </h3>
            </div>

            <!-- Card body — content + image -->
            <div
              class="grid grid-cols-1 md:grid-cols-2 max-md:grid-rows-[60fr_40fr]"
            >
              <!-- LEFT: text content -->
              <div
                class="flex flex-col justify-start px-6 py-6 md:px-10 md:py-8 lg:pl-[5vw] lg:pr-12 lg:py-12 max-md:order-1"
              >
                <h4
                  class="font-heading text-[clamp(2rem,8vw,4.5rem)] font-light text-[#3D3028] leading-[1.05] mb-6 shrink-0"
                >
                  {service.title}
                </h4>

                <!-- Sub-treatments accordion list -->
                <div class="flex flex-col gap-0 shrink-0" data-accordion-group>
                  {service.subTreatments.map((treatment) => (
                    <div
                      class="border-b border-[#3D3028]/10"
                    >
                      {treatment.description && (
                        <details class="group">
                          <summary class="flex items-center justify-between cursor-pointer py-3 px-4 select-none list-none [&::-webkit-details-marker]:hidden hover:bg-[#3D3028]/5 transition-colors duration-200 rounded-sm">
                            <span class="font-body text-[clamp(0.75rem,2vw,0.9rem)] font-normal text-[#5C4E44] leading-relaxed flex items-center gap-3">
                              <span class="text-[#A63228] font-bold text-xs">·</span>
                              {treatment.name}
                            </span>
                            <span class="text-[#A63228] text-xs font-body font-medium tracking-wide shrink-0 ml-4 group-open:hidden">
                              Ver más
                            </span>
                            <span class="text-[#A63228] text-xs font-body font-medium tracking-wide shrink-0 ml-4 hidden group-open:inline">
                              Cerrar
                            </span>
                          </summary>
                          <div class="overflow-hidden transition-all duration-300 ease-in-out" data-accordion-content style="height: 0; opacity: 0;">
                            <p class="font-body text-[clamp(0.7rem,1.8vw,0.825rem)] text-[#5C4E44]/80 leading-relaxed px-4 pb-3 pt-0 pl-[2.25rem] whitespace-pre-line" set:html={boldify(treatment.description)} />
                          </div>
                        </details>
                      )}
                      {!treatment.description && (
                        <span class="font-body text-[clamp(0.75rem,2vw,0.9rem)] font-normal text-[#5C4E44] leading-relaxed flex items-center gap-3 py-3 px-4">
                          <span class="text-[#A63228] font-bold text-xs">·</span>
                          {treatment.name}
                        </span>
                      )}
                    </div>
                  ))}
                </div>

              </div>

              <!-- RIGHT: service image -->
              <div
                class="relative overflow-hidden h-full max-md:order-2"
              >
                <Image
                  src={service.image}
                  alt={service.title}
                  class="w-full h-full object-cover object-center"
                  width={800}
                  height={900}
                />
              </div>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<script>
  function closeDetails(detail: HTMLDetailsElement): Promise<void> {
    return new Promise((resolve) => {
      const content = detail.querySelector('[data-accordion-content]') as HTMLElement;
      if (!content) {
        detail.removeAttribute('open');
        resolve();
        return;
      }

      content.style.height = `${content.scrollHeight}px`;
      content.style.opacity = '1';

      requestAnimationFrame(() => {
        content.style.height = '0';
        content.style.opacity = '0';

        const onEnd = () => {
          content.removeEventListener('transitionend', onEnd);
          detail.removeAttribute('open');
          resolve();
        };
        content.addEventListener('transitionend', onEnd, { once: true });

        // Safety fallback in case transitionend doesn't fire
        setTimeout(() => {
          detail.removeAttribute('open');
          resolve();
        }, 350);
      });
    });
  }

  function openDetails(detail: HTMLDetailsElement): void {
    detail.setAttribute('open', '');
    const content = detail.querySelector('[data-accordion-content]') as HTMLElement;
    if (!content) return;

    content.style.height = '0';
    content.style.opacity = '0';

    requestAnimationFrame(() => {
      content.style.height = `${content.scrollHeight}px`;
      content.style.opacity = '1';

      const onEnd = () => {
        content.removeEventListener('transitionend', onEnd);
        // After animation, set height to auto so it adapts to content changes
        content.style.height = 'auto';
      };
      content.addEventListener('transitionend', onEnd, { once: true });
    });
  }

  // Exclusive animated accordion
  document.querySelectorAll('[data-accordion-group]').forEach((group) => {
    const allDetails = group.querySelectorAll('details');

    allDetails.forEach((detail) => {
      const summary = detail.querySelector('summary');
      if (!summary) return;

      summary.addEventListener('click', (e) => {
        e.preventDefault();

        if (detail.open) {
          // Close this one
          closeDetails(detail);
        } else {
          // Close any other open details in this group, then open this one
          const closePromises: Promise<void>[] = [];
          allDetails.forEach((other) => {
            if (other !== detail && other.open) {
              closePromises.push(closeDetails(other));
            }
          });

          // Open after others finish closing (or immediately if none open)
          Promise.all(closePromises).then(() => {
            openDetails(detail);
          });
        }
      });
    });
  });

</script>
