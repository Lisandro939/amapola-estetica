import masajes from '../assets/masajes.png';
import manicura from '../assets/manicura.png';
import pestanas from '../assets/pestañas.png';

function boldify(text: string): string {
  return text.replace(/\*([^*]+)\*/g, '<strong>$1</strong>');
}

const services = [
  {
    title: "Depilación",
    description:
      "Ofrecemos depilación tradicional y depilación definitiva, adaptada a tu tipo de piel. Atención profesional y personalizada junto con productos y herramientas de calidad.",
    subTreatments: [
      { name: "Definitiva Soprano Ice", description: "¿Qué es?\n\nLa depilación láser Soprano es una tecnología de depilación láser de diodo que utiliza pulsos de baja energía y alta repetición para debilitar el vello de forma progresiva. A diferencia de otros láseres de diodo, la Soprano no elimina el vello folículo por folículo con altas energías, sino que calienta la dermis de forma gradual para eliminar el folículo permanentemente.\n\nCaracterísticas principales:\n\n*Tecnología:* Láser de diodo con pulsos de baja energía y alta repetición.\n\n*Mecanismo de acción:* Calienta la dermis de forma gradual para eliminar el folículo permanentemente.\n\n*Beneficios:*\nPuede ser utilizada en todo tipo de piel y vello. Permite depilar pieles bronceadas.\n\n*Ventajas:*\nMenos dolor y más cómoda que otros métodos de depilación. No requiere analgésicos o sistemas de enfriamiento adicionales.\n\n*Número de sesiones:*\nEl número de sesiones necesarias varía según el tipo de vello, la zona a tratar y la respuesta individual del paciente. En promedio, se recomiendan de 6 a 8 sesiones para obtener resultados óptimos y duraderos.\nLas sesiones se programan con intervalos de tiempo adecuados (4 a 8 semanas) para permitir que los folículos pilosos pasen por las diferentes fases del ciclo de crecimiento.\n\n*Resultados:*\nLos resultados pueden durar varios meses o incluso años, y muchas personas experimentan una reducción permanente del vello. La caída del vello puede producirse entre una y tres semanas después de cada sesión. Después de completar el tratamiento, la piel suele quedar suave y sin vello." },
      { name: "Depilación con cera", description: "La depilación con cera es uno de los métodos más tradicionales y efectivos para eliminar el vello de raíz. A diferencia de la rasuradora, que solo corta el pelo superficialmente, la cera garantiza una suavidad duradera y una mejora progresiva en la textura del vello.\n\n*Principales Beneficios:*\n*Resultados Prolongados:* Disfruta de una piel suave entre 3 y 4 semanas, dependiendo del ciclo de crecimiento personal.\n*Debilitamiento del Vello:* Con el tiempo y la constancia, el vello nace cada vez más fino, claro y escaso.\n\n*Recomendaciones para un mejor resultado:*\n*Exfoliación:* Realiza una exfoliación suave 24 horas antes para evitar vellos encarnados.\n*Hidratación Post-Depilación:* Aplica geles calmantes (como aloe vera) para refrescar la zona y reducir el enrojecimiento natural.\n*Protección Solar:* Evita la exposición directa al sol inmediatamente después de la sesión para proteger la sensibilidad de la piel." },
      { name: "Perfilado de cejas", description: "El perfilado de cejas es una técnica de diseño personalizada que busca potenciar la belleza natural del rostro, respetando las facciones y la morfología de cada persona. A diferencia de una depilación común, el perfilado se basa en mediciones precisas para encontrar la forma ideal que armonice con tus ojos y facciones.\n\n*Beneficios de un Perfilado Profesional:*\n*Simetría:* Ayuda a corregir visualmente pequeñas irregularidades entre ambas cejas.\n*Personalización Total:* No existen \"cejas de molde\"; el diseño se adapta a la estructura ósea y al crecimiento natural del vello.\n*Limpieza y Definición:* Define el arco de la ceja, eliminando incluso los vellos más finos que suelen pasar desapercibidos.\n\n*Mantenimiento Sugerido:*\nPara conservar el diseño y la prolijidad, se recomienda realizar un mantenimiento profesional cada 21 a 30 días, evitando retocar por cuenta propia los vellos que forman parte de la estructura principal." },
      { name: "Laminado de cejas", description: "El laminado de cejas es la tendencia ideal para quienes buscan unas cejas con más cuerpo, definición y un aspecto peinado de forma semipermanente. Es el tratamiento perfecto para domar vellos rebeldes o para dar la ilusión de unas cejas mucho más tupidas sin necesidad de maquillaje diario.\n\n*¿Qué es el Laminado de Cejas?*\nA menudo descrito como el \"lifting\" de las cejas, es un tratamiento estético que reposiciona el vello natural para lograr una dirección uniforme.\n\n*Beneficios Principales:*\n*Volumen Inmediato:* Crea un efecto de cejas más gruesas al instante.\n*Orden y Control:* Ideal para vellos que crecen de forma irregular o hacia abajo, manteniéndolos en su lugar todo el día.\n*Resultados Duraderos:* El efecto suele mantenerse impecable entre 4 y 6 semanas.\n\n*Cuidados Post-Tratamiento:*\nPara asegurar la durabilidad del laminado, es fundamental no mojar las cejas ni aplicar vapor durante las primeras 48 horas. Pasado ese tiempo, solo necesitas peinarlas suavemente cada mañana para que luzcan perfectas.\n*Recomendación:* Este servicio se puede combinar con un tinte de cejas para un resultado de alto impacto, ideal para quienes desean un color más intenso y definido." },
      { name: "Depilación con hilo", description: "La depilación con hilo es una técnica milenaria, que se ha convertido en el método favorito de quienes buscan una definición impecable y máxima suavidad. A diferencia de otros métodos, utiliza un lazo de hilo 100% de algodón para atrapar y extraer el vello de raíz con precisión.\n\n*Ideal para Pieles Sensibles:* Al no utilizar calor ni productos químicos, no irrita ni levanta la piel. Es perfecta para personas con cutis sensible o que utilizan tratamientos dermatológicos.\n\n*Resultados de Larga Duración:* Al extraer el folículo completo, el vello tarda entre 3 y 4 semanas en volver a aparecer, naciendo cada vez más débil.\n*Dato Extra:* Al ser una técnica natural que no estira la piel, es el método más recomendado para prevenir la flacidez prematura en el área de los párpados." },
    ],
    gradientFrom: "#f8d7d7",
    gradientTo: "#f0b8b8",
    cardBg: "#F9F3EC",
    headerBg: "#F0E8E0",
    accentColor: "#A63228",
    icon: "✦",
    image: depilacion,
  },
  {
    title: "Tratamientos Faciales",
    description:
      "Tratamientos específicos para limpieza, renovación y mantenimiento de la piel del rostro. Cada sesión se adapta al tipo de piel y a los objetivos de cada persona.",
    subTreatments: [
      { name: "Peeling enzimático", description: "" },
      { name: "Peeling de invierno", description: "" },
      { name: "Peeling de algas", description: "" },
      { name: "Peeling mecánico con punta de diamantes", description: "" },
      { name: "Limpieza profunda con extracciones", description: "" },
      { name: "Dermaplaning", description: "" },
      { name: "Dermapen", description: "" },
      { name: "Nano botox", description: "" },
      { name: "Hilos líquidos, sólidos y planos", description: "" },
      { name: "Radiofrecuencia", description: "" },
      { name: "Tratamiento para papada", description: "" },
      { name: "Hollywood peel", description: "¿Qué es?\nEs un tratamiento láser que ayuda a rejuvenecer la apariencia de la piel dañada o envejecida. Este suave tratamiento es seguro en todos los tipos de piel y en cualquier momento del año, incluso en verano. Es perfecto para manejar tu piel facial tanto de imperfecciones cutáneas como de manchas sin el tiempo de recuperación que requieren otros tratamientos láser.\n\nEl procedimiento es extremadamente seguro y suave para la piel, es indoloro y se puede seguir con las actividades normales.\n\nEstá indicado para:\n👉 Pieles grasas\n👉 Cerrar los poros\n👉 Unificar los tonos de piel\n👉 Dar luminosidad\n👉 Suavizar las arrugas finas dejando un aspecto más joven.\n\nUna vez terminado el tratamiento podrías sentir algo de picazón o molestia, o presentar una leve inflamación o enrojecimientos, pero en cualquiera de los casos se pasarán a los pocos minutos." },
      { name: "Oxígenoterapia", description: "" },
      { name: "HIFU", description: "¿Qué es?\nSe trata de ultrasonido focalizado de alta intensidad. Mediante su aplicación reactiva la producción de colágeno." },
      { name: "Exilis", description: "¿Qué es?\nEs un tratamiento no invasivo que utiliza tecnología de radiofrecuencia y ultrasonido para reducir la grasa y la flacidez en el cuerpo. Además en rostro se utiliza para arrugas y flacidez.\n\n¿Cómo funciona?\nEl tratamiento funciona calentando la piel y la capa subcutánea debajo de ella mediante ondas de radiofrecuencia y ultrasonido. Esto estimula la producción de colágeno y elastina, que son dos proteínas que ayudan a mantener la piel firme y tonificada. A medida que se produce más colágeno y elastina, la piel se vuelve más firme y la flacidez disminuye.\n\nAdemás, el calentamiento también ayuda a descomponer las células de grasa en el área tratada. El cuerpo luego elimina naturalmente estas células a través del sistema linfático, lo que resulta en una reducción de la grasa y una mejora en la forma corporal." },
    ],
